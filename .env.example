# Required: Upstream Core API (same idea as bds-agent BDS_BASE_URL). Catalog GETs go here — not the MCP server's own hostname.
BDS_MCP_BASE_URL=https://your-snapshotter-full-node.example

# Required: Metering service origin (used for GET /credits/balance validation)
BDS_MCP_METERING_URL=https://your-metering.example

# Required: one of — local endpoints.json OR remote URL
# Example (BDS Mainnet Uniswap V3 catalog): https://raw.githubusercontent.com/powerloom/snapshotter-computes/refs/heads/bds_eth_uniswapv3_core/api/endpoints.json
BDS_MCP_CATALOG_PATH=
BDS_MCP_CATALOG_URL=

# Optional: bind (default 0.0.0.0:8808)
BDS_MCP_HOST=0.0.0.0
BDS_MCP_PORT=8808

# Optional: comma-separated path prefixes to filter catalog entries (default /mpp). Use "all" for no filter.
BDS_MCP_CATALOG_PATH_PREFIXES=/mpp

# Optional: Powerloom chain JSON-RPC for verify_data_provenance (eth_call)
BDS_MCP_POWERLOOM_RPC_URL=

# Optional: contract addresses (mainnet BDS defaults shown)
BDS_MCP_PROTOCOL_STATE_ADDRESS=0x1d0e010Ff11b781CA1dE34BD25a0037203e25E2a
BDS_MCP_DATA_MARKET_ADDRESS=0x26c44e5CcEB7Fe69Cffc933838CF40286b2dc01a

# Optional: TTL seconds for in-memory metering validation cache (default 60)
BDS_MCP_AUTH_CACHE_TTL_SECONDS=60

# Reserved for future internal billing integration (Phase 2)
# BDS_MCP_INTERNAL_BILLING_SECRET=
